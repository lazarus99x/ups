{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "staff", "customer"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Shipment": {
      "title": "Shipment",
      "description": "Shipment details and tracking information",
      "type": "object",
      "properties": {
        "trackingNumber": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverName": { "type": "string" },
        "receiverEmail": { "type": "string", "format": "email" },
        "origin": { "type": "string" },
        "destination": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "On Hold", "Delivered", "Cancelled"] },
        "currentLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": { "type": "string", "format": "date-time" },
              "status": { "type": "string" },
              "location": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "estimatedDelivery": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["trackingNumber", "status", "origin", "destination"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/shipments/{shipmentId}": {
      "schema": "Shipment",
      "description": "Shipment records"
    }
  }
}
